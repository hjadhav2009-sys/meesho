generator client {
  provider = "prisma-client-js"
}

// Supabase/PostgreSQL production schema. Use with:
// npx prisma migrate deploy --schema prisma/schema.postgres.prisma
// Production SQL migrations live in prisma/migrations-postgres.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  PICKER
  PACKER
}

enum BatchStatus {
  UPLOADED
  PARSED
  REVIEWED
  IMPORTED
  FAILED
}

enum ImportType {
  ORDER_LABEL
  SKU_IMAGE
}

enum PaymentType {
  PREPAID
  COD
  UNKNOWN
}

enum OrderStatus {
  READY
  PACKED
  PROBLEM
}

enum PickStatus {
  READY
  PICKED
  PROBLEM
}

enum PackStatus {
  READY
  PACKED
  PROBLEM
}

enum ScanOutcome {
  FOUND
  PACKED
  PROBLEM
  NOT_FOUND
}

enum ProblemStatus {
  OPEN
  RESOLVED
}

enum ImageHealth {
  UNKNOWN
  MAPPED
  BROKEN
}

enum ImageCacheStatus {
  NOT_CACHED
  CACHED
  BROKEN
  RECHECK_NEEDED
}

model User {
  id                 String              @id @default(cuid())
  username           String              @unique
  passwordHash       String
  name               String
  role               Role
  active             Boolean             @default(true)
  mustChangePassword Boolean             @default(false)
  failedLoginCount   Int                 @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  lastLoginIp        String?
  lastUserAgent      String?
  accountId          String?
  account            Account?            @relation(fields: [accountId], references: [id], onDelete: SetNull)
  uploadedBatches    UploadBatch[]       @relation("UploadedBatches")
  scanLogs           ScanLog[]           @relation("UserScanLogs")
  problemOrders      ProblemOrder[]      @relation("ReportedProblems")
  sessions           UserDeviceSession[]
  auditLogs          AuditLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model UserDeviceSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  active      Boolean  @default(true)

  @@index([userId, active])
  @@index([lastSeenAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  accountId  String?
  account    Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([accountId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Account {
  id               String            @id @default(cuid())
  name             String            @unique
  code             String            @unique
  users            User[]
  skuImageMappings SkuImageMapping[]
  uploadBatches    UploadBatch[]
  orders           Order[]
  scanLogs         ScanLog[]
  problemOrders    ProblemOrder[]
  auditLogs        AuditLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model SkuImageMapping {
  id                    String           @id @default(cuid())
  accountId             String
  account               Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sku                   String
  imageUrl              String
  productName           String?
  color                 String?
  size                  String?
  active                Boolean          @default(true)
  lastImportedAt        DateTime?
  source                String?
  notes                 String?
  imageHealth           ImageHealth      @default(UNKNOWN)
  cacheStatus           ImageCacheStatus @default(NOT_CACHED)
  cacheFilePath         String?
  cacheContentType      String?
  cacheOriginalImageUrl String?
  cacheCachedAt         DateTime?
  cacheLastUsedAt       DateTime?
  cacheWidth            Int?
  cacheHeight           Int?
  cacheFileSizeBytes    Int?
  cacheError            String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([accountId, sku])
  @@index([sku])
  @@index([accountId, active])
  @@index([accountId, imageHealth])
  @@index([accountId, cacheStatus])
  @@index([cacheLastUsedAt])
}

model UploadBatch {
  id               String             @id @default(cuid())
  accountId        String
  account          Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdByUserId  String?            @map("uploadedById")
  createdBy        User?              @relation("UploadedBatches", fields: [createdByUserId], references: [id], onDelete: SetNull)
  fileName         String             @map("filename")
  importType       ImportType         @default(ORDER_LABEL)
  status           BatchStatus        @default(UPLOADED)
  totalRows        Int                @default(0)
  createdRows      Int                @default(0)
  updatedRows      Int                @default(0)
  duplicateRows    Int                @default(0)
  missingImageRows Int                @default(0)
  skippedRows      Int                @default(0)
  errorRows        Int                @default(0)
  notes            String?
  orders           Order[]
  issues           ImportRowIssue[]
  previewRows      UploadPreviewRow[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([accountId, createdAt])
  @@index([accountId, importType, createdAt])
}

model Order {
  id                 String         @id @default(cuid())
  accountId          String
  account            Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  batchId            String?        @map("uploadBatchId")
  uploadBatch        UploadBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  awb                String
  courier            String?
  sku                String
  qty                Int            @default(1) @map("quantity")
  color              String?
  size               String?
  orderNo            String         @map("orderNumber")
  productDescription String?
  paymentType        PaymentType    @default(UNKNOWN)
  imageUrl           String?
  city               String?
  state              String?
  pickStatus         PickStatus     @default(READY)
  packStatus         PackStatus     @default(READY)
  status             OrderStatus    @default(READY)
  packedAt           DateTime?
  importedAt         DateTime       @default(now())
  scanLogs           ScanLog[]
  problemOrders      ProblemOrder[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([accountId, awb])
  @@index([accountId, sku])
  @@index([accountId, orderNo])
  @@index([accountId, packStatus])
  @@index([accountId, pickStatus])
  @@index([accountId, status])
}

model ScanLog {
  id          String      @id @default(cuid())
  accountId   String
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  awb         String
  outcome     ScanOutcome
  scannedById String?
  scannedBy   User?       @relation("UserScanLogs", fields: [scannedById], references: [id], onDelete: SetNull)
  note        String?
  createdAt   DateTime    @default(now())

  @@index([accountId, createdAt])
  @@index([awb])
}

model ProblemOrder {
  id           String        @id @default(cuid())
  accountId    String
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason       String
  details      String?
  status       ProblemStatus @default(OPEN)
  reportedById String?
  reportedBy   User?         @relation("ReportedProblems", fields: [reportedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([accountId, status])
  @@index([orderId])
}

model ImportRowIssue {
  id        String      @id @default(cuid())
  batchId   String
  batch     UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rowNumber Int?
  issueType String
  message   String
  rawData   String?
  createdAt DateTime    @default(now())

  @@index([batchId, issueType])
}

model UploadPreviewRow {
  id                 String      @id @default(cuid())
  batchId            String
  batch              UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  sourceType         String
  pageNumber         Int?
  awb                String?
  courier            String?
  sku                String?
  qty                Int?
  color              String?
  size               String?
  orderNo            String?
  productDescription String?
  paymentType        PaymentType @default(UNKNOWN)
  confidence         Int         @default(0)
  rawData            String?
  issues             String?
  imported           Boolean     @default(false)
  createdAt          DateTime    @default(now())

  @@index([batchId, sourceType])
  @@index([batchId, awb])
  @@index([batchId, sku])
}
