DATABASE_URL=<supabase postgres url>
SESSION_SECRET=<long secret>
# Optional. Defaults to SESSION_SECRET for signed cached image URLs.
# IMAGE_CACHE_SECRET=<long image cache secret>
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Meesho Pick & Pack
SESSION_COOKIE_SECURE=false
LOCAL_NETWORK_ONLY=false
NODE_ENV=production

# For Cloudflare Tunnel HTTPS, use:
